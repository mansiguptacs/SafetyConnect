# ---- xAI (Grok) : OpenAI-compatible API ----
XAI_API_KEY=
XAI_MODEL=grok-4.3
# Realtime voice model for the voice survey (grok-voice-latest | grok-voice-fast-1.0)
XAI_VOICE_MODEL=grok-voice-latest

# ---- ClickHouse (local binary in dev; ClickHouse Cloud for deploy) ----
CLICKHOUSE_URL=http://127.0.0.1:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=safetyconnect

# ---- openFDA (optional API key raises the rate limit) ----
OPENFDA_API_KEY=

# ---- Telegram (optional: one real demo alert to a phone) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- App base URL (used to build the patient survey link in alerts) ----
APP_URL=http://localhost:3000

# ---- Inngest ----
# For local dev set INNGEST_DEV=1 (enables endpoint introspection w/o a signing key).
# For Inngest Cloud deploy, set the event + signing keys instead.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
