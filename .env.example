# ---- xAI (Grok) : OpenAI-compatible API ----
XAI_API_KEY=
XAI_MODEL=grok-4.3

# ---- ClickHouse (local binary in dev; ClickHouse Cloud for deploy) ----
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=safetyconnect

# ---- openFDA (optional API key raises the rate limit) ----
OPENFDA_API_KEY=

# ---- Telegram (optional: one real demo alert to a phone) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Inngest ----
# For local dev set INNGEST_DEV=1 (enables endpoint introspection w/o a signing key).
# For Inngest Cloud deploy, set the event + signing keys instead.
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
